        text-wrap: true
        text-align: center
        text-vertical-auto-resize: true
        font: verdana-11px-monochrome
        color: #d7d7d7

    Label
      id: premiumBenefitsFooter
      !text: tr('... and many more!')
      anchors.left: parent.left
      anchors.bottom: parent.bottom
      margin-left: 8
      text-auto-resize: true
      font: verdana-11px-monochrome
      color: #d7d7d7

    HorizontalSeparator
      anchors.left: parent.left
      anchors.right: parent.right
      anchors.bottom: parent.bottom
      margin-left: 8
      margin-right: 8
      height: 2

  Panel
    id: buttonHidden
    anchors.left: parent.left
    anchors.bottom: autoReconnect.top
    margin-bottom: 6
    size: 165 22
    border-width-top: 1
    border-color-top: black
    border-width-left: 1
    border-color-left: black
    border-width-bottom: 1
    border-color-bottom: #747474
    border-width-right: 1
    border-color-right: #747474
    @onSetup: |
      if not(g_game.getFeature(GameEnterGameShowAppearance)) then
        self:setHeight(0)
        self:setMarginBottom(0)
        self:hide()
      else
        self:setHeight(22)
        self:setMarginBottom(6)
      end
    CheckBox
      id: checkBoxHidden
      anchors.left: parent.left
      anchors.verticalCenter: parent.verticalCenter
      margin-left: 6
      checked: true
      !text: tr('Show Hidden Characters')
      text-auto-resize: true
      color: #c0c0c0
      @onCheckChange: onShowHiddenCharacters(self, self:isChecked())


  Panel
    id: buttonOutfit
    anchors.left: buttonHidden.right
    anchors.verticalCenter: buttonHidden.verticalCenter
    margin-left: 10
    size: 100 22
    border-width-top: 1
    border-color-top: black
    border-width-left: 1
    border-color-left: black
    border-width-bottom: 1
    border-color-bottom: #747474
    border-width-right: 1
    border-color-right: #747474
    padding: 1 1 1 1
    @onSetup: |
      if not(g_game.getFeature(GameEnterGameShowAppearance)) then
        self:setHeight(0)
        self:hide()
      else
        self:setHeight(22)
      end
    CheckBox
      id: checkBoxOutfit
      anchors.left: parent.left
      anchors.verticalCenter: parent.verticalCenter
      margin-left: 6      
      !text: tr('Show Outfit')
      text-auto-resize: true
      color: #c0c0c0
      @onCheckChange: onShowOutfits(self, self:isChecked())

  Button
    id: autoReconnect
    anchors.left: parent.left
    anchors.bottom: parent.bottom
    @onSetup: |
      if g_game.getFeature(GameEnterGameShowAppearance) then
        self:setWidth(140)
      else
        self:setWidth(75)
        self:setFont('small-9px')
      end
    $!on:
      image-color: red
    $on:
      image-color: green

  Button
    id: buttonOk
    !text: tr('Ok')
    width: 64
    anchors.right: next.left
    anchors.bottom: parent.bottom
    margin-right: 10
    @onClick: CharacterList.doLogin()

  Button
    id: buttonCancel
    !text: tr('Cancel')
    width: 64
    anchors.right: parent.right
    anchors.bottom: parent.bottom
    @onClick: CharacterList.hide(true)
