        self:hide()
      end

  CheckBoxButton
    id: pin
    size: 12 12
    anchors.top: parent.top
    anchors.left: parent.left
    margin-left: 236
    margin-top: 2
    visible: false
    tooltip: Pin this character to have it always shown at the top of the list.
    icon-source: /game_questlog/images/icon-pin
    @onSetup: |
      if not(g_game.getFeature(GameEnterGameShowAppearance)) then
        self:hide()
      end
    @onCheckChange: onPinCharacter(self, self:isChecked())
    $checked:
      tooltip: Remove pin from this character.
      image-color: red

  Label
