    anchors.top: characters.top
    height: 19
    border-width: 1
    border-color-top: #1B1B1A
    border-color-left: #1B1B1A
    border-color-right: #6b6b6b
    border-color-bottom: #6b6b6b
    background-color: #363636
    @onSetup: |
      if not(g_game.getFeature(GameEnterGameShowAppearance)) then
        self:hide()
      end

    UIButton
