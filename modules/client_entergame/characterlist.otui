      if g_game.getFeature(GameEnterGameShowAppearance) then
        self:setMarginBottom(15)
        self:setPaddingBottom(2)
        self:addAnchor(AnchorBottom, 'separator', AnchorBottom)
      end


  HorizontalSeparator
    id: separator
    anchors.left: parent.left
    anchors.right: parent.right
    anchors.bottom: premiumBenefitsPanel.top
    height: 2
    @onSetup: |
      if g_game.getFeature(GameEnterGameShowAppearance) then
        self:setMarginBottom(6)
      else
        self:setMarginBottom(10)
      end

  Panel
    id: premiumBenefitsPanel
    anchors.left: parent.left
    anchors.right: parent.right
    anchors.bottom: buttonHidden.top

    @onSetup: |
      if not(g_game.getFeature(GameEnterGameShowAppearance)) then
        self:setHeight(0)
        self:setMarginBottom(0)
        self:hide()
      end


    Label
      id: premiumBenefitsTitle
      !text: tr('Premium Benefits include:')
      anchors.top: parent.top
      anchors.horizontalCenter: parent.horizontalCenter
      margin-top: 2
      padding-left: 6
      padding-right: 6
      color: #cfcfcf
      font: verdana-11px-monochrome
      text-auto-resize: true

    UIWidget
      id: premiumBenefitSpells
      size: 210 52
      anchors.left: parent.left
      anchors.top: parent.top
      margin-top: 22
      margin-left: 12

      UIWidget
        id: premiumBenefitSpellsIcon
        size: 32 32
        anchors.top: parent.top
        anchors.horizontalCenter: parent.horizontalCenter
        image-source: /images/game/entergame/premium-icons-32x32
        image-clip: 32 0 32 32

      Label
        id: premiumBenefitSpellsText
        !text: tr('No level cap while training your skills offline')
        anchors.top: premiumBenefitSpellsIcon.bottom
        anchors.horizontalCenter: parent.horizontalCenter
        margin-top: 2
        font: verdana-11px-monochrome
        color: #d7d7d7
        width: 160
        text-wrap: true
        text-align: center
        text-vertical-auto-resize: true

    UIWidget
      id: premiumBenefitMounts
      size: 210 52
      anchors.horizontalCenter: parent.horizontalCenter
      anchors.top: parent.top
      margin-top: 22

      UIWidget
